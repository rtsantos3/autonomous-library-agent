# NCBI / PubMed
NCBI_API_KEY=

# Semantic Scholar (optional, increases rate limit from 1 to 10 req/s)
S2_API_KEY=

# Crossref (email for polite pool, higher rate limit)
CROSSREF_EMAIL=

# Unpaywall (email required)
UNPAYWALL_EMAIL=

# Trellis workspace — the directory containing .trellis/ (the graph data store).
# Trellis instantiates a workspace in whatever directory it runs in. setup.sh
# sets this to the repo root so the deploy is self-contained; leave blank to
# fall back to the code default (the repo's parent directory).
TRELLIS_WORKSPACE=
