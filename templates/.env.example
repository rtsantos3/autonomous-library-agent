# NCBI / PubMed
NCBI_API_KEY=

# Semantic Scholar (optional, increases rate limit from 1 to 10 req/s)
S2_API_KEY=

# Crossref (email for polite pool, higher rate limit)
CROSSREF_EMAIL=

# Unpaywall (email required)
UNPAYWALL_EMAIL=

# Trellis workspace — OPTIONAL runtime override. The persistent setting lives in
# config.yml (`workspace:`), set by setup.sh. Use this env var only for one-off
# runs / tests / CI that need to target a different library without editing
# config.yml. Precedence: this var > config.yml > default (the repo's parent dir).
TRELLIS_WORKSPACE=
