# Secrets
.env

# Local library data — never committed
data/
vault/

# Conda environment
setup/

# Trellis workspace — the graph DB IS tracked so the network topology is shared
# via git. Only the transient SQLite sidecar files are ignored: they are runtime
# WAL/lock artifacts, not durable data. Checkpoint the WAL into trellis.db before
# committing (e.g. `sqlite3 .trellis/trellis.db 'PRAGMA wal_checkpoint(TRUNCATE);'`)
# so the committed db is complete.
.trellis/*.db-wal
.trellis/*.db-shm

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# One-off scripts
screenshot*.py
scaffold_5.py
preview_papers.py
diag.py

# Editor
.DS_Store
*.swp

# Benchmark results — accumulate locally, not committed
tests/results/
